import sys
import json
import random
from PyQt5.QtWidgets import (
    QApplication, QWidget, QVBoxLayout, QHBoxLayout,
    QSlider, QPushButton, QTableWidget, QTableWidgetItem,
    QCheckBox, QLabel, QMessageBox
)
from PyQt5.QtCore import Qt

HISTORY_FILE = 'history.json'

def load_history():
    try:
        with open(HISTORY_FILE, 'r') as f:
            return json.load(f)
    except FileNotFoundError:
        return []

def save_history(history):
    with open(HISTORY_FILE, 'w') as f:
        json.dump(history, f, indent=4)

class PasswordGenerator(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Random Password Generator")
        self.setGeometry(100, 100, 600, 400)
        self.history = load_history()
        self.init_ui()

    def init_ui(self):
        layout = QVBoxLayout()

        # Настройки длины пароля
        length_layout = QHBoxLayout()
        length_label = QLabel("Длина пароля:")
        self.length_slider = QSlider(Qt.Horizontal)
        self.length_slider.setMinimum(4)
        self.length_slider.setMaximum(32)
        self.length_slider.setValue(12)
        self.length_slider.setTickInterval(1)
        self.length_slider.setTickPosition(QSlider.TicksBelow)
        self.length_value_label = QLabel(str(self.length_slider.value()))
        self.length_slider.valueChanged.connect(
            lambda: self.length_value_label.setText(str(self.length_slider.value()))
        )

        length_layout.addWidget(length_label)
        length_layout.addWidget(self.length_slider)
        length_layout.addWidget(self.length_value_label)
        layout.addLayout(length_layout)

        # Чекбоксы для символов
        self.chk_digits = QCheckBox("Цифры (0-9)")
        self.chk_letters = QCheckBox("Буквы (a-Z)")
        self.chk_symbols = QCheckBox("Спецсимволы (!@#$...)")
        self.chk_digits.setChecked(True)
        self.chk_letters.setChecked(True)
        self.chk_symbols.setChecked(False)

        symbols_layout = QHBoxLayout()
        symbols_layout.addWidget(self.chk_digits)
        symbols_layout.addWidget(self.chk_letters)
        symbols_layout.addWidget(self.chk_symbols)
        layout.addLayout(symbols_layout)

        # Кнопка генерации
        generate_btn = QPushButton("Сгенерировать")
        generate_btn.clicked.connect(self.generate_password)
        layout.addWidget(generate_btn)

        # Таблица истории
        self.history_table = QTableWidget()
        self.history_table.setColumnCount(2)
        self.history_table.setHorizontalHeaderLabels(["Пароль", "Дата"])
        layout.addWidget(QLabel("История:"))
        layout.addWidget(self.history_table)

        self.setLayout(layout)
        self.load_history_into_table()

    def load_history_into_table(self):
        self.history_table.setRowCount(0)
        for entry in self.history:
            row_idx = self.history_table.rowCount()
            self.history_table.insertRow(row_idx)
            self.history_table.setItem(row_idx, 0, QTableWidgetItem(entry['password']))
            self.history_table.setItem(row_idx, 1, QTableWidgetItem(entry['date']))

    def generate_password(self):
        length = self.length_slider.value()

        charset = ""
        if self.chk_digits.isChecked():
            charset += "0123456789"
        if self.chk_letters.isChecked():
            charset += "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
        if self.chk_symbols.isChecked():
            charset += "!@#$%^&*()-_=+[]{}|;:'\",.<>?/"

        if not charset:
            QMessageBox.warning(self, "Ошибка", "Выберите хотя бы один тип символов.")
            return

        password = ''.join(random.choice(charset) for _ in range(length))

        # Добавляем в историю
        import datetime
        now_str = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        self.history.append({'password': password, 'date': now_str})
        save_history(self.history)
        self.load_history_into_table()

        QMessageBox.information(self, "Пароль сгенерирован", password)

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = PasswordGenerator()
    window.show()
    sys.exit(app.exec_())
